# Postgres connection for the fbads schema (Supabase pooler, transaction mode)
# Username format for the pooler is role.project-ref
DATABASE_URL=postgres://fbads_app.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Supabase project ref hosting the fbads schema (used by Claude Code skills via MCP execute_sql)
SUPABASE_PROJECT_ID=

# Shared access password for the hosted app (leave unset to disable the login gate locally)
ADMIN_PASSWORD=
